@{
    ViewData["Title"] = "Logify | Home";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Logify</h1>
        <p class="lead text-muted">
            Simple, powerful workforce tracking for modern companies.
        </p>
        <hr class="w-25 mx-auto" />
    </div>
    <div class="row justify-content-center mb-5">
        <div class="col-md-8 text-center">
            <p>
                Logify helps companies manage employees, track time,
                and streamline operations — all from one centralized platform.
            </p>
        </div>
    </div>
    <div class="row text-center mb-3">
        <div class="col-md-4 mb-3">
            <a asp-controller="Company" asp-action="Portal"
               class="btn btn-dark btn-lg w-100">
                Company Portal
            </a>
        </div>

        <div class="col-md-4 mb-3">
            <a asp-controller="Manager" asp-action="Portal"
               class="btn btn-secondary btn-lg w-100">
                Manager Portal
            </a>
        </div>
        <div class="col-md-4 mb-3">
            <a asp-controller="Employee" asp-action="Portal"
               class="btn btn-outline-dark btn-lg w-100">
                Employee Portal
            </a>
        </div>
    </div>
    <div class="d-flex justify-content-center align-items-center mt-3">
         <div class="col-md-4 mb-3">
             <a asp-controller="Company" asp-action="Register"
                class="btn btn-danger btn-lg w-100">
                Register
             </a>
         </div>
    </div>
</div>
