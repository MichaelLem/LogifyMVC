@{
	ViewData["Title"] = "Logify | Managers Dashboard";
}

<div class="container d-flex flex-column justify-content-center">
	<div class="h2 fw-semibold text-center mb-4">Logify</div>
	<div class="container">
		<div class="col-12 col-lg-8 mx-auto">
			<div class="card shadow-lg rounded-4 p-4">
				<div class="mb-4 text-center">
					<h1 class="h4 fw-semibold mb-1">Managers Dashboard</h1>
					<p class="text-secondary mb-0">
						Welcome <span id="user-name"></span>
						<span class="mx-1">&bull;</span>
						<span id="co-name"></span>
						<span class="mx-1">&bull;</span>
						<span id="pay-period"></span>
					</p>
				</div>
				<div class="d-grid gap-2">
					<a class="btn btn-dark fw-semibold" asp-controller="Manager" asp-action="ViewLogs">View Time Logs</a>
					<a class="btn btn-outline-dark fw-semibold" asp-controller="Manager" asp-action="EmployeeList">Employee List</a>
					<a class="btn btn-outline-dark fw-semibold" asp-controller="Logify" asp-action="TimeTracker">Time Clock (Logify)</a>
				</div>
				<hr class="my-4" />
				<div class="d-flex flex-column flex-md-row justify-content-between text-center gap-3">
					<a asp-controller="Manager" asp-action="Portal" class="text-decoration-none fw-semibold">Managers Portal</a>
					<a asp-controller="Company" asp-action="Portal" class="text-decoration-none fw-semibold">Company Portal</a>
				</div>
			</div>
		</div>
	</div>
</div>