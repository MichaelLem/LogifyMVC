@{
    ViewData["Title"] = "Logify | Time Tracker";
}

<div class="container d-flex flex-column justify-content-center">
	<h1 class="h2 fw-semibold mb-4 text-center">Logify</h1>
	<div class="container">
		<div class="col-12 col-lg-10 mx-auto">
			<div class="card shadow-lg rounded-4 p-4">
				<div class="mb-4 text-center">
					<p class="text-secondary mb-0">
						Welcome <span id="employee"></span>
						<span class="mx-1">&bull;</span>
						<span id="co-name"></span>
						<span class="mx-1">&bull;</span>
						<span id="pay-period"></span>
					</p>
				</div>
				<div class="row g-3 align-items-start">
					<div class="col-12 col-lg-6">
						<div class="d-grid gap-3">
							<div class="border rounded-3 p-2">
								<button class="btn btn-dark w-100 fw-semibold" id="btn-clock-in" type="button">Clock In</button>
								<p class="mt-1 mb-0 small text-secondary">Clock In: <span id="timer-clock-in">00:00:00</span></p>
							</div>
							<div class="border rounded-3 p-2">
								<button class="btn btn-outline-dark w-100 fw-semibold" id="btn-start-break" type="button">Start Break</button>
								<p class="mt-1 mb-0 small text-secondary">Start Break: <span id="timer-start-break">00:00:00</span></p>
							</div>
							<div class="border rounded-3 p-2">
								<button class="btn btn-outline-dark w-100 fw-semibold" id="btn-end-break" type="button">End Break</button>
								<p class="mt-1 mb-0 small text-secondary">End Break: <span id="timer-end-break">00:00:00</span></p>
							</div>
							<div class="border rounded-3 p-2">
								<button class="btn btn-outline-danger w-100 fw-semibold" id="btn-clock-out" type="button">Clock Out</button>
								<p class="mt-1 mb-0 small text-secondary">Clock Out: <span id="timer-clock-out">00:00:00</span></p>
							</div>
						</div>
					</div>
					<div class="col-12 col-lg-6">
						<div class="border rounded-3 p-2 h-100">
							<label for="txb-notes" class="form-label fw-semibold">Notes</label>
							<form>
								<textarea id="txb-notes"
										  class="form-control"
										  rows="10"
										  placeholder="Write notes for this shift...">
										</textarea>
								<button class="btn btn-primary w-100 mt-3 fw-semibold" type="submit">Save Notes</button>
							</form>
						</div>
					</div>
				</div>
				<hr class="my-4">
				<div class="text-center mt-3">
					<nav class="d-flex justify-content-center gap-3">
						<a asp-controller="Manager" asp-action="Portal" class="nav-link p-0 link-primary text-decoration-underline">Managers Portal</a>
						<a asp-controller="Employee" asp-action="Portal" class="nav-link p-0 link-primary text-decoration-underline">Employee Portal</a>
					</nav>
				</div>
			</div>
		</div>
	</div>
</div>