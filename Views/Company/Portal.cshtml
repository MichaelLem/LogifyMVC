@{
    ViewData["Title"] = "Logify | Company Portal";
}

<div class="container d-flex flex-column justify-content-center">
	<div class="container text-center">
		<div class="container py-3 text-center">
			<h2 class="fw-bold">
				Company Portal
			</h2>
			<p class="text-muted">
				This is the starting point for company admins.
			</p>
		</div>
		<div class="col-12 col-sm-10 col-md-6 col-lg-4 mx-auto">
			<h2 class="h2 fw-semibold text-center mb-4">Logify</h2>
			<div class="card shadow-lg rounded-4 p-4">
				<div class="mb-4 text-center">
					<h1 class="h4 mb-0">Company Portal</h1>
				</div>
				<form asp-controller="Company" asp-action="Portal" method="post">
					<div class="mb-3">
						<label class="form-label" for="username">Username:</label>
						<input class="form-control"
							   id="username"
							   name="username"
							   type="text"
							   placeholder="Enter username..."
							   required>
					</div>
					<div class="mb-3">
						<label class="form-label" for="password">Password:</label>
						<input class="form-control"
							   id="password"
							   name="password"
							   type="password"
							   placeholder="Enter password..."
							   required>
					</div>
					<div class="w-100 d-block">
						<button type="submit" class="btn btn-danger w-100">Sign In</button>
					</div>
				</form>
				<hr class="my-3">
				<div class="text-center">
					<span class="text-secondary">Not registered?</span>
					<a asp-controller="Company" asp-action="Register" class="ms-1">Register</a>
				</div>
			</div>
		</div>
	</div>
</div>